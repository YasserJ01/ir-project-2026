# ─── Service URLs (backend) ───────────────────────────────
GATEWAY_URL=http://localhost:8000
PREPROCESSING_URL=http://localhost:8001
INDEXING_URL=http://localhost:8002
RETRIEVAL_URL=http://localhost:8003
REFINEMENT_URL=http://localhost:8004
RAG_URL=http://localhost:8005

# ─── Frontend ─────────────────────────────────────────────
VITE_API_BASE_URL=/api
VITE_DEV_PORT=5173

# ─── Data paths ───────────────────────────────────────────
DATA_DIR=./data
RAW_DIR=./data/raw
PROCESSED_DIR=./data/processed
INDEXES_DIR=./data/indexes
FAISS_DIR=./data/faiss
USER_LOGS_DIR=./data/user_logs

# ─── Default models ───────────────────────────────────────
EMBEDDING_MODEL_DEFAULT=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_MODEL_OPTIONAL=sentence-transformers/msmarco-MiniLM-L6-cos-v5
BM25_K1_DEFAULT=1.5
BM25_B_DEFAULT=0.75
RRF_K_DEFAULT=60

# ─── RAG (Phase 8) ────────────────────────────────────────
# Local generator: "ollama" or "hf"
RAG_GENERATOR=ollama
RAG_MODEL=llama3.1:8b
RAG_FALLBACK_MODEL=google/flan-t5-base
RAG_TOP_K=5
RAG_MAX_CONTEXT_TOKENS=2000

# ─── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
