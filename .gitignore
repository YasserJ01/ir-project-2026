# ─── OS / Editor ──────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# ─── Secrets ──────────────────────────────────────────────
.env
.env.local
.env.*.local

# ─── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
.nox/
dist/
build/
*.whl

# ─── Virtual envs ─────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ─── Node / React ─────────────────────────────────────────
node_modules/
dist/
build/
.vite/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.eslintcache
.stylelintcache

# ─── Data (large, regenerable) ────────────────────────────
data/raw/*
data/processed/*
data/indexes/*
data/faiss/*
data/models/*
data/user_logs/*
data/dicts/*
data/grammar/*
data/downloads/*
!data/**/.gitkeep
# Logs + scratch files + pid files written at data/ root by background scripts
data/*.log
data/*.err
data/*.json
data/*.pid
!data/.gitkeep

# ─── Project artefacts ────────────────────────────────────
evaluation/results/*
evaluation/reports/plots/*
!evaluation/**/.gitkeep
reports/*.pdf
!reports/.gitkeep

# ─── Temporary files ──────────────────────────────────────
tmp_*
tmp*.txt
tmp*.log

# ─── OS / Windows extras ──────────────────────────────────
$RECYCLE.BIN/
System Volume Information/
*.lnk
